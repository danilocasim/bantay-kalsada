# Firebase web app config
# Copy this file to .env.local for local development.
# These values are public client config values from Firebase Console -> Project settings -> Your apps -> Web app.

VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Optional: only needed when enabling web push notifications.
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_public_key
