rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAgency() {
      return isSignedIn()
        && (request.auth.token.role == 'agency_official' || request.auth.token.role == 'admin');
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isConfirmCountUpdate(reportId) {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmCount', 'updatedAt'])
        && request.resource.data.confirmCount == resource.data.confirmCount + 1
        && resource.data.reporterUid != request.auth.uid
        && existsAfter(/databases/$(database)/documents/reports/$(reportId)/confirmations/$(request.auth.uid));
    }
    function isCommunityReopen() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && resource.data.status in ['resolved', 'community_verified']
        && request.resource.data.status == 'reopened';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow read: if true; // public reports
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'submitted';
      allow update: if isSignedIn()
        && (isAgency() || isConfirmCountUpdate(reportId) || isCommunityReopen());
      allow delete: if isAgency();

      match /confirmations/{uid} {
        allow read: if true;
        allow create: if isSignedIn()
          && isOwner(uid)
          && get(/databases/$(database)/documents/reports/$(reportId)).data.reporterUid != request.auth.uid;
        allow delete: if isOwner(uid);
      }

      match /statusEvents/{eventId} {
        allow read: if true;
        allow create: if isAgency();
      }
    }

    match /agencies/{id} {
      allow read: if true;
      allow write: if false; // managed via admin tools / functions
    }

    match /fcmTokens/{uid}/tokens/{tokenId} {
      allow read, write: if isOwner(uid);
    }
  }
}
