rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAgency() { return request.auth.token.role == 'agency_official'; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow read: if true; // public reports
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'submitted';
      allow update: if isSignedIn()
        && (isOwner(resource.data.reporterUid) || isAgency());
      allow delete: if isAgency();

      match /confirmations/{uid} {
        allow read: if true;
        allow create: if isSignedIn()
          && isOwner(uid)
          && get(/databases/$(database)/documents/reports/$(reportId)).data.reporterUid != request.auth.uid;
        allow delete: if isOwner(uid);
      }

      match /statusEvents/{eventId} {
        allow read: if true;
        allow create: if isAgency();
      }
    }

    match /agencies/{id} {
      allow read: if true;
      allow write: if false; // managed via admin tools / functions
    }

    match /fcmTokens/{uid}/tokens/{tokenId} {
      allow read, write: if isOwner(uid);
    }
  }
}